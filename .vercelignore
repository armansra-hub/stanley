# Vercel CLI upload filter. When this file exists it REPLACES .gitignore for
# deploy uploads — which is the point: .gitignore excludes public/art/* (personal
# art, deliberately not in the repo), and that silently kept the background
# images out of every deployment (pictures 404'd in prod). This list mirrors
# .gitignore EXCEPT the art block, so the images ship with the deploy while
# secrets and build junk stay out.
node_modules
.pnp
.pnp.*
.next
out
build
.env
.env.local
.env*.local
.env*
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
supabase/.branches
supabase/.temp
tsconfig.tsbuildinfo
.git
