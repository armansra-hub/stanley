# ── Jarvis env — copy to .env.local and fill in. NEVER commit .env.local. ──

# Anthropic (classification/scoring summaries + chatbot)
ANTHROPIC_API_KEY=

# Apify (all paid scrapers). Actor IDs live in app_config.actors, not here.
APIFY_TOKEN=
# Some Crunchbase actors need their own key; leave blank if yours doesn't.
CRUNCHBASE_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side ONLY — never expose to the client

# Shared secret protecting /api/cron/* and /api/webhooks/* routes
CRON_SECRET=

# Auth gate — leave BLANK for local (no login). On Vercel set BOTH to enable a
# single-user password login: APP_PASSWORD = what you type; APP_SESSION_TOKEN =
# any long random string (the session cookie value).
APP_PASSWORD=
APP_SESSION_TOKEN=

# Optional CSV-upload enrichment helper (not used for discovery)
APOLLO_API_KEY=

# Optional: free Socrata app token raises FMCSA census rate limits
# (https://data.transportation.gov/profile/edit/developer_settings)
SOCRATA_APP_TOKEN=
